# Roadmap Design Skill - LLM Configuration Example
# Copy this file to .env and fill in your values

# Provider: openai, alibaba, openrouter, local, or none (default: none)
LLM_PROVIDER=none

# OpenAI Configuration
# OPENAI_API_KEY=your-openai-api-key
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1

# Alibaba DashScope Configuration
# DASHSCOPE_API_KEY=your-dashscope-api-key
# LLM_MODEL=qwen-plus
# LLM_BASE_URL=https://dashscope.aliyuncs.com/v1

# OpenRouter Configuration
# OPENROUTER_API_KEY=your-openrouter-api-key
# LLM_MODEL=openai/gpt-4o-mini
# LLM_BASE_URL=https://openrouter.ai/api/v1

# Local LLM Configuration (Ollama, LM Studio, etc.)
# LLM_MODEL=llama3
# LLM_BASE_URL=http://localhost:11434/v1

# Optional Settings
# LLM_TIMEOUT_SECONDS=180
# LLM_MAX_TOKENS=8192
# LLM_TEMPERATURE=0.7

# CLI/HTTP LLM Enable Flags (set to 1 to enable LLM by default)
# RDS_CLI_USE_LLM=1
# RDS_HTTP_USE_LLM=1