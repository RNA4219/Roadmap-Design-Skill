{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roadmap-design-skill.local/schemas/validation-result.schema.json",
  "title": "Roadmap Design Skill Validation Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mode",
    "valid",
    "errors",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "mode": {
      "type": "string",
      "const": "roadmap"
    },
    "valid": {
      "type": "boolean"
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validationIssue"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validationIssue"
      }
    }
  },
  "$defs": {
    "validationIssue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "field",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "field": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
